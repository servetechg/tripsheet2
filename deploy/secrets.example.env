# Copy to /opt/tripsheet/secrets/ on the VPS. Never commit real values.
# chmod 700 /opt/tripsheet/secrets && chmod 600 /opt/tripsheet/secrets/*

# --- infra.env ---
POSTGRES_USER=tripsheet
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# --- app.env ---
POSTGRES_USER=tripsheet
POSTGRES_PASSWORD=CHANGE_ME_same_as_infra
REDIS_PASSWORD=CHANGE_ME_same_as_infra
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_EXPIRES_IN=7d
INTERNAL_API_KEY=CHANGE_ME_openssl_rand_hex_32
CORS_ORIGIN=https://tripsheet.YOUR_REAL_VPS_IP.sslip.io
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tripsheet/documents
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
IMAGE_REGISTRY=ghcr.io/YOUR_GITHUB_ORG/tripsheet
IMAGE_TAG=latest
COLOR=blue

# --- edge.env ---
DOMAIN=tripsheet.YOUR_REAL_VPS_IP.sslip.io
ACTIVE_COLOR=blue
CADDY_ACME_EMAIL=you@example.com
