{
	email {$CADDY_ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip

	# Liveness for the edge itself (used by deploy health checks)
	handle /healthz {
		respond "ok" 200
	}

	handle /api* {
		reverse_proxy {$ACTIVE_COLOR}-gateway:3000
	}

	handle /health {
		reverse_proxy {$ACTIVE_COLOR}-gateway:3000
	}

	handle {
		reverse_proxy {$ACTIVE_COLOR}-frontend:80
	}
}
