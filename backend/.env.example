# Shared infrastructure
POSTGRES_USER=tripsheet
POSTGRES_PASSWORD=tripsheet
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (shared secret for auth + gateway validation later)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Cloudinary (Phase 2 — document uploads via driver-service)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tripsheet/documents

# Service URLs (used by gateway)
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
COMPANY_SERVICE_URL=http://localhost:3002
DRIVER_SERVICE_URL=http://localhost:3003
FLEET_SERVICE_URL=http://localhost:3004
MANIFEST_SERVICE_URL=http://localhost:3005
TRIPSHEET_SERVICE_URL=http://localhost:3006
ACCOUNTING_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008

# Twilio (optional — notification-service; without these, SMS is simulated)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Database URLs
AUTH_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/auth_db?schema=public
COMPANY_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/company_db?schema=public
DRIVER_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/driver_db?schema=public
FLEET_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/fleet_db?schema=public
MANIFEST_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/manifest_db?schema=public
TRIPSHEET_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/tripsheet_db?schema=public
ACCOUNTING_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/accounting_db?schema=public
NOTIFICATION_DATABASE_URL=postgresql://tripsheet:tripsheet@localhost:5432/notification_db?schema=public
